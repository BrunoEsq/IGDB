{
  "buildCommand": "echo 'Build complete'",
  "devCommand": "npx vercel dev",
  "installCommand": "npm install",
  "framework": "vanilla",
  "env": {
    "IGDB_CLIENT_ID": {
      "description": "Client ID from IGDB API",
      "required": true
    },
    "IGDB_ACCESS_TOKEN": {
      "description": "Access Token from IGDB API",
      "required": true
    },
    "CORS_ALLOWED_ORIGINS": {
      "description": "Comma-separated list of allowed origins",
      "value": "https://yourdomain.com"
    }
  },
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
